# Copy this file to `.env` and fill in your Supabase connection strings.
# Prisma CLI reads `.env` only (not `.env.example`).

# Pooled connection (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used for migrations (`prisma migrate`)
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
